
# Используем официальный образ Node.js на Alpine Linux.
# Alpine значительно меньше обычного Debian-образа,
# благодаря чему уменьшается размер итогового Docker-образа.
FROM node:22-alpine AS base

# Рабочая директория внутри контейнера.
WORKDIR /app

# Включаем Corepack.
#
# Corepack входит в состав Node.js и позволяет использовать
# современные пакетные менеджеры (pnpm, yarn) без их
# глобальной установки.
RUN corepack enable


###############################################################################
# Stage: deps
# Установка зависимостей
###############################################################################

FROM base AS deps

# Устанавливаем пакет совместимости glibc.
#
# Некоторые npm-пакеты используют бинарные зависимости,
# которым необходима библиотека libc6.
RUN apk add --no-cache libc6-compat

# Копируем только файлы,
# необходимые для установки зависимостей.
#
# Благодаря этому Docker сможет использовать cache,
# если package.json не изменялся.
COPY package.json ./
COPY pnpm-lock.yaml ./
COPY pnpm-workspace.yaml ./

# Устанавливаем зависимости.
#
# --frozen-lockfile гарантирует,
# что lock-файл не будет изменён.
RUN pnpm install --frozen-lockfile


###############################################################################
# Stage: builder
# Сборка приложения
###############################################################################

FROM base AS builder

# Build-time DATABASE_URL нужен Next.js для импорта server modules во время сборки.
# Страницы, которые реально читают базу, должны быть dynamic, чтобы SQL-запрос выполнялся runtime.
ARG DATABASE_URL=postgres://postgres:123456@postgres:5432/nextjs-course
ENV DATABASE_URL=$DATABASE_URL

# Копируем уже установленные зависимости.
COPY --from=deps /app/node_modules ./node_modules

# Копируем весь исходный код приложения.
COPY . .

# Выполняем production-сборку Next.js.
RUN pnpm run build


###############################################################################
# Stage: runner
# Минимальный production-образ
###############################################################################

FROM base AS runner

# Указываем production-режим.
ENV NODE_ENV=production

# Порт приложения.
ENV PORT=3000

# Слушаем все сетевые интерфейсы.
ENV HOSTNAME=0.0.0.0

###############################################################################
# Создание пользователя
###############################################################################

# Создаём отдельную группу.
RUN addgroup --system --gid 1001 nodejs

# Создаём пользователя,
# под которым будет работать приложение.
#
# Запуск не под root является хорошей практикой безопасности.
RUN adduser --system --uid 1001 nextjs

###############################################################################
# Копирование production-файлов
###############################################################################

# Статические ресурсы.
COPY --from=builder /app/public ./public

# Standalone-сборка Next.js.
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./

# Статические ассеты Next.js.
COPY --from=builder --chown=nextjs:nodejs /app/.next/static ./.next/static

###############################################################################
# Запуск приложения
###############################################################################

# Переключаемся на непривилегированного пользователя.
USER nextjs

# Открываем порт приложения.
EXPOSE 3000

# Запускаем production-сервер.
CMD ["node", "server.js"]
